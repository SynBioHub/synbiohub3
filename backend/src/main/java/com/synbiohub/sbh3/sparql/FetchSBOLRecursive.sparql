PREFIX sbol: <http://sbols.org/v2#>
PREFIX sbh: <http://wiki.synbiohub.org/wiki/Terms/synbiohub#>
CONSTRUCT {?s ?p ?o} $fromClause WHERE {
    {
        SELECT DISTINCT ?s WHERE {
             { ?s sbh:topLevel <$uri> . }
             UNION
             { <$uri> sbol:sequence ?s . }
        }
        ORDER BY ?s
    }
    ?s ?p ?o
}
LIMIT 10000
OFFSET $offset
